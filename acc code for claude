import { Switch, Route, Router as WouterRouter, Redirect } from "wouter";
import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import { Toaster } from "@/components/ui/toaster";
import { AuthProvider, useAuth } from "@/contexts/AuthContext";
import { CartProvider } from "@/contexts/CartContext";
import { isFirebaseConfigured } from "@/lib/firebase";
import LoginPage from "@/pages/LoginPage";
import ProfileSetupPage from "@/pages/ProfileSetupPage";
import HomePage from "@/pages/HomePage";
import ItemDetailPage from "@/pages/ItemDetailPage";
import CartPage from "@/pages/CartPage";
import CookDashboardPage from "@/pages/CookDashboardPage";
import PostItemPage from "@/pages/PostItemPage";
import OrderSummaryPage from "@/pages/OrderSummaryPage";
import AccountPage from "@/pages/AccountPage";
import FirebaseSetupPage from "@/pages/FirebaseSetupPage";
import NotFound from "@/pages/not-found";

const queryClient = new QueryClient();

function DemoBanner() {
  const { isDemoMode, exitDemoMode, userProfile } = useAuth();
  if (!isDemoMode) return null;
  return (
    <div className="fixed bottom-0 left-0 right-0 z-50 bg-gray-900 text-white px-4 py-2.5 flex items-center justify-between shadow-lg">
      <div className="flex items-center gap-2">
        <span className="text-xs bg-amber-400 text-gray-900 font-bold px-2 py-0.5 rounded-full">DEMO</span>
        <span className="text-xs text-gray-300">
          Viewing as {userProfile?.role === "cook" ? "Cook" : "Buyer"} — {userProfile?.name}
        </span>
      </div>
      <button
        onClick={exitDemoMode}
        className="text-xs text-amber-400 font-semibold hover:text-amber-300 transition-colors"
      >
        Exit Demo →
      </button>
    </div>
  );
}

function AppRoutes() {
  const { firebaseUser, userProfile, loading, isDemoMode } = useAuth();

  if (!isFirebaseConfigured) {
    return <FirebaseSetupPage />;
  }

  if (loading) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-orange-50 to-amber-50 flex flex-col items-center justify-center">
        <div className="text-4xl mb-4">🍱</div>
        <p className="text-orange-500 font-medium">Loading Neighbour Eats...</p>
      </div>
    );
  }

  const isLoggedIn = isDemoMode || !!firebaseUser;
  const hasProfile = isDemoMode || !!userProfile;

  if (!isLoggedIn) return <LoginPage />;
  if (!hasProfile) return <ProfileSetupPage />;

  const role = userProfile?.role;

  return (
    <>
      <Switch>
        {role === "cook" ? (
          <>
            <Route path="/" component={() => <Redirect to="/cook" />} />
            <Route path="/cook" component={CookDashboardPage} />
            <Route path="/cook/post-item" component={PostItemPage} />
            <Route path="/cook/orders" component={OrderSummaryPage} />
            <Route path="/account" component={AccountPage} />
          </>
        ) : (
          <>
            <Route path="/" component={HomePage} />
            <Route path="/item/:id" component={ItemDetailPage} />
            <Route path="/cart" component={CartPage} />
            <Route path="/account" component={AccountPage} />
          </>
        )}
        <Route component={NotFound} />
      </Switch>
      <DemoBanner />
    </>
  );
}

function App() {
  return (
    <QueryClientProvider client={queryClient}>
      <AuthProvider>
        <CartProvider>
          <WouterRouter base={import.meta.env.BASE_URL.replace(/\/$/, "")}>
            <AppRoutes />
          </WouterRouter>
          <Toaster />
        </CartProvider>
      </AuthProvider>
    </QueryClientProvider>
  );
}

export default App;


