    if (isDemoMode) {
      setItems(MOCK_MENU_ITEMS);
      setLoading(false);
      return;
    }
    getTodayMenuItems()
      .then(setItems)
      .finally(() => setLoading(false));
  }, [isDemoMode]);

  const filtered =
    activeCategory === "All"
      ? items
      : items.filter((i) => i.category === activeCategory);

  return (
    <div className="min-h-screen bg-orange-50 pb-16">
      <header className="bg-orange-500 text-white px-4 pt-10 pb-5 sticky top-0 z-10 shadow-md">
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-xl font-bold">Neighbour Eats</h1>
            <p className="text-orange-100 text-xs">
              {userProfile?.locality ?? "Your community"} · {userProfile?.flatNumber}
            </p>
          </div>
          <div className="flex items-center gap-2">
            {/* Cart icon */}
            <button
              onClick={() => navigate("/cart")}
              className="relative w-9 h-9 rounded-full bg-white hover:bg-orange-50 transition-colors flex items-center justify-center text-lg shadow"
              aria-label="Cart"
            >
              <span className="text-orange-600">🛒</span>
              {totalItems > 0 && (
                <span className="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full min-w-[18px] min-h-[18px] flex items-center justify-center leading-none px-1">
                  {totalItems}
                </span>
              )}
            </button>
            {/* Account avatar */}
            <button
              onClick={() => navigate("/account")}
              className="w-9 h-9 rounded-full bg-orange-400 hover:bg-orange-300 transition-colors flex items-center justify-center text-white font-bold text-sm"
              title="My Account"
            >
              {userProfile?.name
                ? userProfile.name.split(" ").slice(0, 2).map((w) => w[0]).join("").toUpperCase()
                : "?"}
            </button>
          </div>
        </div>

        <div className="mt-4 flex gap-2 overflow-x-auto pb-1 scrollbar-hide -mx-1 px-1">
          {CATEGORIES.map((cat) => (
            <button
              key={cat}
              onClick={() => setActiveCategory(cat)}
              className={`flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-all ${
                activeCategory === cat
                  ? "bg-white text-orange-600 shadow"
                  : "bg-orange-400 text-white hover:bg-orange-300"
              }`}
            >
              {cat !== "All" ? `${CATEGORY_EMOJI[cat]} ` : ""}{cat}
            </button>
          ))}
        </div>
      </header>

      <main className="px-4 py-4 max-w-lg mx-auto">
        {loading ? (
          <div className="flex items-center justify-center py-16 text-gray-400">
            Loading today's menu...
          </div>
        ) : filtered.length === 0 ? (
          <div className="text-center py-16 text-gray-400">
            <div className="text-5xl mb-3">🍽️</div>
            <p className="font-medium text-gray-500">No items available yet</p>
            <p className="text-sm mt-1">Check back later when cooks post their menu</p>
          </div>
        ) : (
          <div className="space-y-3">
            <p className="text-xs text-gray-500 font-medium uppercase tracking-wide">
              {filtered.length} item{filtered.length !== 1 ? "s" : ""} available today
            </p>
            {filtered.map((item) => {
              const closed = isPastCutoff(item.cutoffTime);
              const soldOut = item.orderedQuantity >= item.maxQuantity;
              const statusBadge = closed
                ? { label: "Orders Closed", color: "text-red-500 bg-red-50" }
                : soldOut
                ? { label: "Sold Out", color: "text-red-500 bg-red-50" }
                : null;

              return (
                <button
                  key={item.id}
                  onClick={() => !closed && !soldOut && navigate(`/item/${item.id}`)}
                  className={`w-full text-left bg-white rounded-2xl shadow-sm border border-orange-100 overflow-hidden transition-all ${
                    closed || soldOut
                      ? "opacity-75 cursor-not-allowed"
                      : "hover:shadow-md active:scale-[0.99]"
                  }`}
                >
                  {item.imageUrl ? (
                    <img
