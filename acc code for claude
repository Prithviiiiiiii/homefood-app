import { createContext, useContext, useEffect, useState, ReactNode } from "react";
import { User, onAuthStateChanged } from "firebase/auth";
import { auth, isFirebaseConfigured } from "@/lib/firebase";
import { getUserProfile, UserProfile } from "@/lib/firestore";

const DEMO_BUYER: UserProfile = {
  uid: "demo-buyer",
  name: "Ravi Kumar (Demo)",
  phone: "+919800000001",
  flatNumber: "B-204",
  role: "buyer",
  locality: "NCC Urban One",
};

const DEMO_COOK: UserProfile = {
  uid: "demo-cook",
  name: "Priya Sharma (Demo)",
  phone: "+919800000002",
  flatNumber: "A-304",
  role: "cook",
  locality: "NCC Urban One",
};

interface AuthContextValue {
  firebaseUser: User | null;
  userProfile: UserProfile | null;
  loading: boolean;
  isDemoMode: boolean;
  refreshProfile: () => Promise<void>;
  enterDemoMode: (role: "buyer" | "cook") => void;
  exitDemoMode: () => void;
}

const AuthContext = createContext<AuthContextValue>({
  firebaseUser: null,
  userProfile: null,
  loading: true,
  isDemoMode: false,
  refreshProfile: async () => {},
  enterDemoMode: () => {},
  exitDemoMode: () => {},
});

export function AuthProvider({ children }: { children: ReactNode }) {
  const [firebaseUser, setFirebaseUser] = useState<User | null>(null);
  const [firebaseProfile, setFirebaseProfile] = useState<UserProfile | null>(null);
  const [demoProfile, setDemoProfile] = useState<UserProfile | null>(null);
  const [loading, setLoading] = useState(true);

  const userProfile = demoProfile ?? firebaseProfile;
  const isDemoMode = demoProfile !== null;

  const loadProfile = async (user: User) => {
    const profile = await getUserProfile(user.uid);
    setFirebaseProfile(profile);
  };

  const refreshProfile = async () => {
    if (demoProfile) return;
    if (firebaseUser) {
      await loadProfile(firebaseUser);
    }
  };

  const enterDemoMode = (role: "buyer" | "cook") => {
    setDemoProfile(role === "buyer" ? DEMO_BUYER : DEMO_COOK);
  };

  const exitDemoMode = () => {
    setDemoProfile(null);
  };

  useEffect(() => {
    if (!isFirebaseConfigured || !auth) {
      setLoading(false);
      return;
    }

    const unsub = onAuthStateChanged(auth, async (user) => {
      setFirebaseUser(user);
      if (user) {
        await loadProfile(user);
      } else {
        setFirebaseProfile(null);
      }
      setLoading(false);
    });
    return unsub;
  }, []);

  return (
    <AuthContext.Provider
      value={{ firebaseUser, userProfile, loading, isDemoMode, refreshProfile, enterDemoMode, exitDemoMode }}
    >
      {children}
    </AuthContext.Provider>
  );
}

export function useAuth() {
  return useContext(AuthContext);
}


