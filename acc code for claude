import { useState } from "react";
import { useAuth } from "@/contexts/AuthContext";
import { createUserProfile, createCook, LOCALITIES } from "@/lib/firestore";
import { useToast } from "@/hooks/use-toast";

export default function ProfileSetupPage() {
  const { firebaseUser, refreshProfile } = useAuth();
  const [name, setName] = useState("");
  const [flatNumber, setFlatNumber] = useState("");
  const [locality, setLocality] = useState("");
  const [customLocality, setCustomLocality] = useState("");
  const [role, setRole] = useState<"cook" | "buyer">("buyer");
  const [kitchenName, setKitchenName] = useState("");
  const [loading, setLoading] = useState(false);
  const { toast } = useToast();

  const finalLocality = locality === "Other" ? customLocality.trim() : locality;

  const handleSave = async () => {
    if (!name.trim()) {
      toast({ title: "Please enter your name", variant: "destructive" });
      return;
    }
    if (!flatNumber.trim()) {
      toast({ title: "Please enter your flat number", variant: "destructive" });
      return;
    }
    if (!locality) {
      toast({ title: "Please select your society / locality", variant: "destructive" });
      return;
    }
    if (locality === "Other" && !customLocality.trim()) {
      toast({ title: "Please enter your society name", variant: "destructive" });
      return;
    }
    if (role === "cook" && !kitchenName.trim()) {
      toast({ title: "Please enter your kitchen name", variant: "destructive" });
      return;
    }
    if (!firebaseUser) return;

    setLoading(true);
    try {
      const profile = {
        uid: firebaseUser.uid,
        name: name.trim(),
        phone: firebaseUser.phoneNumber || "",
        flatNumber: flatNumber.trim().toUpperCase(),
        role,
        locality: finalLocality,
      };
      await createUserProfile(profile);

      if (role === "cook") {
        await createCook({
          uid: firebaseUser.uid,
          kitchenName: kitchenName.trim(),
          isActive: true,
        });
      }

      await refreshProfile();
    } catch (err: unknown) {
      const error = err as Error;
      toast({ title: "Failed to save profile", description: error.message, variant: "destructive" });
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-orange-50 to-amber-50 flex flex-col items-center justify-center px-4 py-8">
      <div className="w-full max-w-sm">
        <div className="text-center mb-6">
          <div className="text-4xl mb-2">👤</div>
          <h1 className="text-2xl font-bold text-orange-600">Create Your Account</h1>
          <p className="text-sm text-gray-500 mt-1">Tell us a bit about yourself</p>
        </div>

        <div className="bg-white rounded-2xl shadow-lg p-6 space-y-4">
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
            <input
              type="text"
              placeholder="e.g. Priya Sharma"
              value={name}
              onChange={(e) => setName(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Society / Locality</label>
            <select
              value={locality}
              onChange={(e) => setLocality(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors bg-white appearance-none"
            >
              <option value="" disabled>Select your gated community…</option>
              {LOCALITIES.map((loc) => (
                <option key={loc} value={loc}>{loc}</option>
              ))}
            </select>
          </div>

          {locality === "Other" && (
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Enter Society Name</label>
              <input
                type="text"
                placeholder="e.g. Green Valley Apartments"
                value={customLocality}
                onChange={(e) => setCustomLocality(e.target.value)}
                className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
              />
            </div>
          )}

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">Flat / Unit Number</label>
            <input
              type="text"
              placeholder="e.g. A-304"
              value={flatNumber}
              onChange={(e) => setFlatNumber(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">I want to…</label>
            <div className="grid grid-cols-2 gap-3">
              {(["buyer", "cook"] as const).map((r) => (
                <button
                  key={r}
                  onClick={() => setRole(r)}
                  className={`py-3 rounded-xl border-2 font-medium text-sm transition-all ${
                    role === r
                      ? "border-orange-500 bg-orange-50 text-orange-600"
                      : "border-gray-200 text-gray-600 hover:border-orange-300"
                  }`}
                >
                  {r === "buyer" ? "🛒 Order Food" : "👨‍🍳 Sell Food"}
                </button>
              ))}
            </div>
            <p className="text-xs text-gray-400 mt-2 text-center">
              {role === "buyer"
                ? "Browse and order home-cooked meals"
                : "Post your daily menu and take orders"}
            </p>
          </div>

          {role === "cook" && (
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">Kitchen Name</label>
              <input
                type="text"
                placeholder="e.g. Priya's Home Kitchen"
                value={kitchenName}
                onChange={(e) => setKitchenName(e.target.value)}
                className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
              />
            </div>
          )}

          <button
            onClick={handleSave}
            disabled={loading}
            className="w-full py-3.5 bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white font-semibold rounded-xl transition-colors text-base disabled:opacity-60"
          >
            {loading ? "Creating account..." : "Create Account →"}
          </button>
        </div>
      </div>
    </div>
  );
}

