  return now > cutoff;
}

export async function submitReview(
  review: Omit<Review, "id" | "timestamp">
): Promise<string> {
  const ref = await addDoc(collection(getDb(), "reviews"), {
    ...review,
    timestamp: serverTimestamp(),
  });
  return ref.id;
}

export async function getCookReviews(cookId: string): Promise<Review[]> {
  const q = query(
    collection(getDb(), "reviews"),
    where("cookId", "==", cookId),
    orderBy("timestamp", "desc")
  );
  const snap = await getDocs(q);
  return snap.docs.map((d) => ({ id: d.id, ...d.data() } as Review));
}

export function calcAverageRating(reviews: Review[]): number | null {
  if (reviews.length === 0) return null;
  return reviews.reduce((s, r) => s + r.rating, 0) / reviews.length;
}


