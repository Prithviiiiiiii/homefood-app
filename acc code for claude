import { getTodayMenuItems, MenuItem, isPastCutoff, Category } from "@/lib/firestore";
import { MOCK_MENU_ITEMS, MOCK_REVIEWS } from "@/lib/mockData";

const CATEGORIES: ("All" | Category)[] = [
  "All",
  "Breakfast",
  "Lunch",
  "Dinner",
  "Snacks",
  "Desserts",
];

const CATEGORY_EMOJI: Record<string, string> = {
  Breakfast: "🍳",
  Lunch: "🍱",
  Dinner: "🍛",
  Snacks: "🥟",
  Desserts: "🍮",
};

function StarBadge({ cookId }: { cookId: string }) {
  const reviews = MOCK_REVIEWS.filter((r) => r.cookId === cookId);
  if (reviews.length === 0) return null;
  const avg = reviews.reduce((s, r) => s + r.rating, 0) / reviews.length;
  return (
    <span className="flex items-center gap-0.5 text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">
      <span className="text-amber-400">★</span>
      {avg.toFixed(1)} ({reviews.length})
    </span>
  );
}

export default function HomePage() {
  const { userProfile, isDemoMode } = useAuth();
  const { totalItems } = useCart();
  const [, navigate] = useLocation();
  const [items, setItems] = useState<MenuItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [activeCategory, setActiveCategory] = useState<"All" | Category>("All");

