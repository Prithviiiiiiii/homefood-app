type PaymentMethod = "cash" | "upi" | "bank";

const PAYMENT_OPTIONS: { id: PaymentMethod; label: string; icon: string; description: string }[] = [
  { id: "cash", label: "Cash on Delivery", icon: "💵", description: "Pay when the food arrives" },
  { id: "upi", label: "UPI", icon: "📱", description: "GPay, PhonePe, Paytm etc." },
  { id: "bank", label: "Bank Transfer", icon: "🏦", description: "Transfer to cook's account" },
];

const CATEGORY_EMOJI: Record<string, string> = {
  Breakfast: "🍳",
  Lunch: "🍱",
  Dinner: "🍛",
  Snacks: "🥟",
  Desserts: "🍮",
};

function getEtaText(cutoffTime: string): string {
  const [h, m] = cutoffTime.split(":").map(Number);
  const eta = new Date();
  eta.setHours(h, m + 30, 0, 0);
  const hh = eta.getHours();
  const mm = eta.getMinutes().toString().padStart(2, "0");
  const ampm = hh >= 12 ? "PM" : "AM";
  return `${hh % 12 || 12}:${mm} ${ampm}`;
}

export default function CartPage() {
  const [, navigate] = useLocation();
  const { userProfile, firebaseUser, isDemoMode } = useAuth();
  const { items, totalPrice, updateQty, removeFromCart, clearCart } = useCart();
  const { toast } = useToast();

  const [flatNumber, setFlatNumber] = useState(userProfile?.flatNumber || "");
  const [specialNote, setSpecialNote] = useState("");
  const [payment, setPayment] = useState<PaymentMethod>("cash");
  const [placing, setPlacing] = useState(false);

  const paymentLabel = PAYMENT_OPTIONS.find((o) => o.id === payment)?.label ?? "Cash on Delivery";

  const handleCheckout = async () => {
    if (items.length === 0) return;
    if (!flatNumber.trim()) {
      toast({ title: "Please enter your flat number", variant: "destructive" });
      return;
    }

    if (isDemoMode) {
      setPlacing(true);
      await new Promise((r) => setTimeout(r, 900));
      setPlacing(false);
      clearCart();
      toast({
        title: `${items.length} order${items.length > 1 ? "s" : ""} placed! (Demo)`,
        description: `${paymentLabel} · Flat ${flatNumber}`,
      });
      navigate("/");
      return;
    }

    if (!firebaseUser || !userProfile) return;
    setPlacing(true);
    try {
      await Promise.all(
        items.map((item) =>
          placeOrder(
            {
              buyerId: firebaseUser.uid,
              cookId: item.cookId,
              itemId: item.itemId,
              itemName: item.name,
              quantity: item.quantity,
              totalPrice: item.price * item.quantity,
              flatNumber: flatNumber.trim().toUpperCase(),
              specialNote: specialNote.trim(),
              status: "placed",
              paymentMethod: paymentLabel,
            },
            item.itemId
          )
        )
      );
      clearCart();
      toast({
        title: `${items.length} order${items.length > 1 ? "s" : ""} placed!`,
        description: `${paymentLabel} · Flat ${flatNumber.trim().toUpperCase()}`,
      });
      navigate("/");
    } catch (err: unknown) {
      const error = err as Error;
      toast({ title: "Failed to place orders", description: error.message, variant: "destructive" });
    } finally {
      setPlacing(false);
    }
  };

  return (
    <div className="min-h-screen bg-orange-50 pb-24">
      <header className="bg-orange-500 text-white px-4 pt-10 pb-4 flex items-center gap-3">
        <button onClick={() => navigate("/")} className="text-white text-2xl leading-none">
          ←
        </button>
        <h1 className="text-xl font-bold flex-1">
          Your Cart {items.length > 0 && <span className="text-orange-200 font-normal text-base">({items.length} item{items.length > 1 ? "s" : ""})</span>}
        </h1>
      </header>

      <main className="px-4 max-w-lg mx-auto">
        {items.length === 0 ? (
          <div className="flex flex-col items-center justify-center py-24 text-gray-400">
            <div className="text-6xl mb-4">🛒</div>
            <p className="font-semibold text-gray-500 text-lg">Your cart is empty</p>
            <p className="text-sm mt-1">Browse the menu and add items</p>
            <button
              onClick={() => navigate("/")}
              className="mt-6 px-6 py-3 bg-orange-500 text-white font-semibold rounded-xl"
            >
              Browse Menu
            </button>
          </div>
        ) : (
          <>
            {/* Cart items */}
            <div className="bg-white rounded-2xl shadow-sm overflow-hidden mt-4">
              {items.map((item, idx) => (
                <div
                  key={item.itemId}
                  className={`p-4 flex items-start gap-3 ${idx !== items.length - 1 ? "border-b border-gray-100" : ""}`}
                >
                  {/* Image / emoji */}
                  <div className="flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden bg-orange-100 flex items-center justify-center text-3xl">
                    {item.imageUrl ? (
                      <img src={item.imageUrl} alt={item.name} className="w-full h-full object-cover" />
                    ) : (
                      <span>{CATEGORY_EMOJI[item.category] ?? "🍽️"}</span>
                    )}
                  </div>

                  {/* Details */}
                  <div className="flex-1 min-w-0">
                    <div className="flex items-start justify-between gap-1">
                      <div className="min-w-0">
                        <p className="font-semibold text-gray-900 text-sm leading-snug">{item.name}</p>
                        <p className="text-xs text-orange-500 mt-0.5">by {item.cookName}</p>
                        <p className="text-xs text-gray-400 mt-0.5">Cutoff {item.cutoffTime}</p>
                      </div>
                      <button
                        onClick={() => removeFromCart(item.itemId)}
                        className="text-gray-300 hover:text-red-400 transition-colors text-xl leading-none flex-shrink-0 mt-0.5"
                        aria-label="Remove"
                      >
                        ×
                      </button>
                    </div>

                    <div className="flex items-center justify-between mt-2">
                      {/* Qty stepper */}
                      <div className="flex items-center gap-2">
                        <button
                          onClick={() => updateQty(item.itemId, item.quantity - 1)}
                          className="w-8 h-8 rounded-lg border-2 border-orange-300 text-orange-600 font-bold text-lg flex items-center justify-center hover:bg-orange-50 transition-colors"
                        >
                          −
                        </button>
                        <span className="text-base font-bold text-gray-800 w-5 text-center">{item.quantity}</span>
                        <button
                          onClick={() => updateQty(item.itemId, Math.min(item.maxAvailable, item.quantity + 1))}
                          className="w-8 h-8 rounded-lg border-2 border-orange-300 text-orange-600 font-bold text-lg flex items-center justify-center hover:bg-orange-50 transition-colors"
                        >
                          +
                        </button>
                      </div>
                      <p className="font-bold text-orange-600 text-sm">₹{item.price * item.quantity}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            {/* Delivery details */}
            <div className="bg-white rounded-2xl shadow-sm p-4 mt-3 space-y-3">
              <h3 className="font-semibold text-gray-800">Delivery Details</h3>
              <div>
                <label className="block text-sm font-medium text-gray-600 mb-1">Deliver to flat</label>
                <input
                  type="text"
                  value={flatNumber}
                  onChange={(e) => setFlatNumber(e.target.value)}
                  placeholder="e.g. A-304"
                  className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-gray-600 mb-1">
                  Special instructions <span className="font-normal text-gray-400">(optional)</span>
                </label>
                <textarea
                  value={specialNote}
                  onChange={(e) => setSpecialNote(e.target.value)}
                  rows={2}
                  placeholder="e.g. No onions, less spicy…"
                  className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-orange-400 focus:outline-none resize-none transition-colors"
                />
              </div>
            </div>

            {/* ETA strip */}
            <div className="bg-green-50 border border-green-200 rounded-2xl px-4 py-3 mt-3 flex items-center gap-3">
              <span className="text-2xl">🕐</span>
              <div>
                <p className="text-xs text-gray-500 font-medium">Estimated delivery</p>
                <p className="font-bold text-gray-800 text-sm">
                  {items.map((i) => getEtaText(i.cutoffTime)).filter((v, i, a) => a.indexOf(v) === i).join(", ")}
                </p>
                <p className="text-xs text-gray-400">Each cook delivers after their cutoff</p>
              </div>
            </div>

            {/* Payment method */}
            <div className="bg-white rounded-2xl shadow-sm p-4 mt-3">
              <h3 className="font-semibold text-gray-800 mb-3">How will you pay?</h3>
              <div className="space-y-2">
                {PAYMENT_OPTIONS.map((opt) => (
                  <button
                    key={opt.id}
                    onClick={() => setPayment(opt.id)}
                    className={`w-full flex items-center gap-3 p-3.5 rounded-xl border-2 transition-all text-left ${
                      payment === opt.id
                        ? "border-orange-400 bg-orange-50"
                        : "border-gray-200 hover:border-orange-200"
                    }`}
                  >
                    <span className="text-2xl">{opt.icon}</span>
                    <div className="flex-1 min-w-0">
                      <p className={`font-semibold text-sm ${payment === opt.id ? "text-orange-700" : "text-gray-800"}`}>
                        {opt.label}
                      </p>
                      <p className="text-xs text-gray-400">{opt.description}</p>
                    </div>
                    <div className={`w-5 h-5 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-all ${
                      payment === opt.id ? "border-orange-500 bg-orange-500" : "border-gray-300"
                    }`}>
                      {payment === opt.id && <div className="w-2 h-2 rounded-full bg-white" />}
                    </div>
                  </button>
                ))}
              </div>
              {payment !== "cash" && (
                <p className="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 mt-3">
                  {payment === "upi"
                    ? "Cook's UPI ID shared via society WhatsApp after order confirmation."
                    : "Cook's bank details shared after confirmation. Please transfer before pickup."}
                </p>
              )}
            </div>

            {/* Order total + checkout */}
            <div className="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 shadow-xl px-4 py-3 z-30">
              <div className="max-w-lg mx-auto flex items-center gap-4">
                <div className="flex-1 min-w-0">
                  <p className="text-xs text-gray-400">
                    {items.reduce((s, i) => s + i.quantity, 0)} item{items.reduce((s, i) => s + i.quantity, 0) > 1 ? "s" : ""} · {paymentLabel}
                  </p>
                  <p className="text-xl font-bold text-orange-600">₹{totalPrice}</p>
                </div>
                <button
                  onClick={handleCheckout}
                  disabled={placing}
                  className="flex-shrink-0 px-7 py-3.5 bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white font-bold rounded-xl transition-colors text-base disabled:opacity-60"
                >
                  {placing ? "Placing…" : "Place Orders"}
                </button>
              </div>
            </div>
          </>
        )}
      </main>
    </div>
  );
}


