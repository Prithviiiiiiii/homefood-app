import { useState, useRef } from "react";
import { useLocation } from "wouter";
import { useAuth } from "@/contexts/AuthContext";
import { createMenuItem, getTodayDate, Category } from "@/lib/firestore";
import { storage } from "@/lib/firebase";
import { ref, uploadBytes, getDownloadURL } from "firebase/storage";
import { useToast } from "@/hooks/use-toast";

const CATEGORIES: Category[] = ["Breakfast", "Lunch", "Dinner", "Snacks", "Desserts"];

export default function PostItemPage() {
  const { userProfile, isDemoMode } = useAuth();
  const [, navigate] = useLocation();
  const { toast } = useToast();
  const fileInputRef = useRef<HTMLInputElement>(null);

  const [name, setName] = useState("");
  const [description, setDescription] = useState("");
  const [price, setPrice] = useState("");
  const [category, setCategory] = useState<Category>("Lunch");
  const [cutoffTime, setCutoffTime] = useState("12:00");
  const [maxQuantity, setMaxQuantity] = useState("10");
  const [imageFile, setImageFile] = useState<File | null>(null);
  const [imagePreview, setImagePreview] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);

  const handleImageSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    setImageFile(file);
    setImagePreview(URL.createObjectURL(file));
  };

  const handleSubmit = async () => {
    if (!name.trim()) {
      toast({ title: "Please enter a dish name", variant: "destructive" });
      return;
    }
    const priceNum = parseFloat(price);
    if (!price || isNaN(priceNum) || priceNum <= 0) {
      toast({ title: "Please enter a valid price", variant: "destructive" });
      return;
    }
    const maxQty = parseInt(maxQuantity);
    if (!maxQuantity || isNaN(maxQty) || maxQty <= 0) {
      toast({ title: "Please enter a valid max quantity", variant: "destructive" });
      return;
    }
    if (!userProfile) return;

    if (isDemoMode) {
      toast({ title: "Item posted! (Demo)", description: "In the real app this saves to Firebase" });
      navigate("/cook");
      return;
    }

    setLoading(true);
    try {
      let imageUrl: string | undefined;
      if (imageFile) {
        const storageRef = ref(storage, `menu/${userProfile.uid}/${Date.now()}_${imageFile.name}`);
        await uploadBytes(storageRef, imageFile);
        imageUrl = await getDownloadURL(storageRef);
      }

      await createMenuItem({
        cookId: userProfile.uid,
        cookName: userProfile.name,
        name: name.trim(),
        description: description.trim(),
        price: priceNum,
        category,
        cutoffTime,
        maxQuantity: maxQty,
        orderedQuantity: 0,
        date: getTodayDate(),
        isAvailable: true,
        ...(imageUrl ? { imageUrl } : {}),
      });

      toast({ title: "Menu item posted!", description: "Buyers can now see your item" });
      navigate("/cook");
    } catch (err: unknown) {
      const error = err as Error;
      toast({ title: "Failed to post item", description: error.message, variant: "destructive" });
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-orange-50">
      <header className="bg-orange-500 text-white px-4 pt-10 pb-4 flex items-center gap-3 shadow-md">
        <button onClick={() => navigate("/cook")} className="text-white text-2xl leading-none">
          ←
        </button>
        <h1 className="font-semibold text-lg">Post Menu Item</h1>
      </header>

      <main className="px-4 py-5 max-w-lg mx-auto">
        <div className="bg-white rounded-2xl shadow-sm p-5 space-y-4">
          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Dish Name <span className="text-red-400">*</span>
            </label>
            <input
              type="text"
              placeholder="e.g. Hyderabadi Biryani"
              value={name}
              onChange={(e) => setName(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Description <span className="text-gray-400 font-normal">(optional)</span>
            </label>
            <textarea
              rows={2}
              placeholder="What's special about this dish?"
              value={description}
              onChange={(e) => setDescription(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-sm focus:border-orange-400 focus:outline-none transition-colors resize-none"
            />
          </div>

          <div className="grid grid-cols-2 gap-3">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Price (₹) <span className="text-red-400">*</span>
              </label>
              <input
                type="number"
                inputMode="numeric"
                placeholder="e.g. 120"
                value={price}
                onChange={(e) => setPrice(e.target.value)}
                className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1">
                Max Portions <span className="text-red-400">*</span>
              </label>
              <input
                type="number"
                inputMode="numeric"
                placeholder="e.g. 10"
                value={maxQuantity}
                onChange={(e) => setMaxQuantity(e.target.value)}
                className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">Category</label>
            <div className="flex flex-wrap gap-2">
              {CATEGORIES.map((cat) => (
                <button
                  key={cat}
                  onClick={() => setCategory(cat)}
                  className={`px-3 py-1.5 rounded-full text-sm font-medium transition-all ${
                    category === cat
                      ? "bg-orange-500 text-white"
                      : "bg-gray-100 text-gray-600 hover:bg-orange-100"
                  }`}
                >
                  {cat}
                </button>
              ))}
            </div>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Order Cutoff Time
            </label>
            <input
              type="time"
              value={cutoffTime}
              onChange={(e) => setCutoffTime(e.target.value)}
              className="w-full border-2 border-gray-200 rounded-xl px-4 py-3 text-base focus:border-orange-400 focus:outline-none transition-colors"
            />
            <p className="text-xs text-gray-400 mt-1">
              Buyers can order until this time
            </p>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-1">
              Food Photo{" "}
              <span className="text-gray-400 font-normal">(optional)</span>
            </label>
            <input
              ref={fileInputRef}
              type="file"
              accept="image/*"
              className="hidden"
              onChange={handleImageSelect}
            />
            {imagePreview ? (
              <div className="relative">
                <img
                  src={imagePreview}
                  alt="Preview"
                  className="w-full h-40 object-cover rounded-xl"
                />
                <button
                  onClick={() => {
                    setImageFile(null);
                    setImagePreview(null);
                  }}
                  className="absolute top-2 right-2 bg-black/50 text-white rounded-full w-7 h-7 flex items-center justify-center text-sm"
                >
                  ✕
                </button>
              </div>
            ) : (
              <button
                onClick={() => fileInputRef.current?.click()}
                className="w-full border-2 border-dashed border-gray-300 rounded-xl py-6 text-gray-400 text-sm hover:border-orange-300 hover:text-orange-400 transition-colors"
              >
                📸 Tap to add photo
              </button>
            )}
          </div>

          <button
            onClick={handleSubmit}
            disabled={loading}
            className="w-full py-4 bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white font-bold rounded-xl transition-colors text-base disabled:opacity-60"
          >
            {loading ? "Posting..." : "Post Item"}
          </button>
        </div>
      </main>
    </div>
  );
}


