import { useState, useEffect } from "react";
import { useParams, useLocation } from "wouter";
import { useAuth } from "@/contexts/AuthContext";
import { useCart } from "@/contexts/CartContext";
import {
  getMenuItem,
  getCookReviews,
  isPastCutoff,
  MenuItem,
  Review,
  calcAverageRating,
} from "@/lib/firestore";
import { MOCK_MENU_ITEMS, MOCK_REVIEWS } from "@/lib/mockData";
import { useToast } from "@/hooks/use-toast";

const CATEGORY_EMOJI: Record<string, string> = {
  Breakfast: "🍳",
  Lunch: "🍱",
  Dinner: "🍛",
  Snacks: "🥟",
  Desserts: "🍮",
};

export default function ItemDetailPage() {
  const params = useParams<{ id: string }>();
  const [, navigate] = useLocation();
  const { isDemoMode } = useAuth();
  const { addToCart, getQty, totalItems } = useCart();
  const { toast } = useToast();
  const [item, setItem] = useState<MenuItem | null>(null);
  const [loading, setLoading] = useState(true);
  const [quantity, setQuantity] = useState(1);
  const [reviews, setReviews] = useState<Review[]>([]);

  useEffect(() => {
    if (isDemoMode) {
      const found = MOCK_MENU_ITEMS.find((i) => i.id === params.id) ?? null;
      setItem(found);
      if (found) setReviews(MOCK_REVIEWS.filter((r) => r.cookId === found.cookId));
      setLoading(false);
      return;
    }
    if (params.id) {
      getMenuItem(params.id).then((found) => {
        setItem(found);
        if (found) getCookReviews(found.cookId).then(setReviews);
      }).finally(() => setLoading(false));
    }
  }, [params.id, isDemoMode]);

  const handleAddToCart = () => {
    if (!item) return;

    if (isPastCutoff(item.cutoffTime)) {
      toast({ title: "Orders are closed for this item", variant: "destructive" });
      return;
    }
    const alreadyInCart = getQty(item.id);
    if (alreadyInCart + quantity > (item.maxQuantity - item.orderedQuantity)) {
      toast({
        title: "Not enough portions available",
        description: `Only ${item.maxQuantity - item.orderedQuantity - alreadyInCart} more portion(s) available`,
        variant: "destructive",
      });
      return;
    }

    addToCart(
      {
        itemId: item.id,
        name: item.name,
        cookId: item.cookId,
        cookName: item.cookName,
        price: item.price,
        category: item.category,
        cutoffTime: item.cutoffTime,
        maxAvailable: item.maxQuantity - item.orderedQuantity,
        imageUrl: item.imageUrl,
      },
      quantity
    );

    toast({
      title: `Added to cart!`,
      description: `${quantity} × ${item.name}`,
    });
  };

  if (loading) {
    return (
      <div className="min-h-screen bg-orange-50 flex items-center justify-center text-gray-400">
        Loading...
      </div>
    );
  }

  if (!item) {
    return (
      <div className="min-h-screen bg-orange-50 flex items-center justify-center">
        <div className="text-center text-gray-500">
          <p>Item not found</p>
          <button onClick={() => navigate("/")} className="text-orange-500 mt-2">Go back</button>
        </div>
      </div>
    );
  }

  const closed = isPastCutoff(item.cutoffTime);
  const soldOut = item.orderedQuantity >= item.maxQuantity;
  const remaining = item.maxQuantity - item.orderedQuantity;
  const avgRating = calcAverageRating(reviews);
  const inCart = getQty(item.id);

  return (
    <div className="min-h-screen bg-orange-50 pb-24">
      <header className="bg-orange-500 px-4 pt-10 pb-4 flex items-center gap-3">
        <button onClick={() => navigate("/")} className="text-white text-2xl leading-none">←</button>
        <h1 className="text-white font-semibold text-lg truncate flex-1">{item.name}</h1>
        {/* Cart icon */}
        <button
          onClick={() => navigate("/cart")}
          className="relative text-white text-2xl leading-none"
          aria-label="Go to cart"
        >
          🛒
          {totalItems > 0 && (
            <span className="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center leading-none">
              {totalItems}
            </span>
          )}
        </button>
      </header>

      <main className="px-4 pb-8 max-w-lg mx-auto">
        {item.imageUrl ? (
          <img src={item.imageUrl} alt={item.name} className="w-full h-52 object-cover rounded-b-2xl mb-4" />
        ) : (
          <div className="w-full h-40 bg-orange-100 flex items-center justify-center text-7xl rounded-b-2xl mb-4">
            {CATEGORY_EMOJI[item.category] ?? "🍽️"}
          </div>
        )}

        <div className="bg-white rounded-2xl shadow-sm p-5 space-y-4">
          <div>
            <h2 className="text-xl font-bold text-gray-900">{item.name}</h2>
            <div className="flex items-center gap-2 mt-0.5 flex-wrap">
              <p className="text-orange-500 text-sm">by {item.cookName}</p>
              {avgRating !== null && (
                <span className="flex items-center gap-0.5 text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full">
                  <span className="text-amber-400">★</span>
                  {avgRating.toFixed(1)}
                  <span className="text-gray-400 font-normal">({reviews.length})</span>
                </span>
              )}
            </div>
            {item.description && <p className="text-gray-600 text-sm mt-2">{item.description}</p>}
          </div>

          <div className="grid grid-cols-3 gap-3 text-center">
            <div className="bg-orange-50 rounded-xl p-3">
              <p className="text-xs text-gray-500">Price</p>
              <p className="text-orange-600 font-bold text-lg">₹{item.price}</p>
            </div>
            <div className="bg-orange-50 rounded-xl p-3">
              <p className="text-xs text-gray-500">Cutoff</p>
              <p className="font-semibold text-gray-800 text-base">{item.cutoffTime}</p>
            </div>
            <div className="bg-orange-50 rounded-xl p-3">
              <p className="text-xs text-gray-500">Left</p>
              <p className={`font-semibold text-base ${remaining === 0 ? "text-red-500" : "text-green-600"}`}>
                {remaining}
              </p>
            </div>
          </div>

          {(closed || soldOut) && (
            <div className="bg-red-50 border border-red-200 rounded-xl p-3 text-center">
              <p className="text-red-600 font-semibold text-sm">
                {closed ? "Orders are closed for this item" : "This item is sold out"}
              </p>
            </div>
          )}
        </div>

        {/* Add to cart */}
        {!soldOut && !closed && (
          <div className="bg-white rounded-2xl shadow-sm p-5 mt-3">
            <label className="block text-sm font-medium text-gray-700 mb-3">Quantity</label>
            <div className="flex items-center gap-4 mb-4">
              <button
                onClick={() => setQuantity((q) => Math.max(1, q - 1))}
                className="w-11 h-11 rounded-xl border-2 border-orange-300 text-orange-600 text-xl font-bold flex items-center justify-center hover:bg-orange-50 transition-colors"
              >
                −
              </button>
              <span className="text-2xl font-bold text-gray-800 w-8 text-center">{quantity}</span>
              <button
                onClick={() => setQuantity((q) => Math.min(remaining, q + 1))}
                className="w-11 h-11 rounded-xl border-2 border-orange-300 text-orange-600 text-xl font-bold flex items-center justify-center hover:bg-orange-50 transition-colors"
              >
                +
              </button>
              <span className="text-gray-400 text-sm ml-auto">₹{item.price * quantity}</span>
            </div>

            {inCart > 0 && (
              <p className="text-xs text-green-600 font-medium mb-2 text-center">
                ✓ {inCart} already in cart — tap to add more
              </p>
            )}

            <button
              onClick={handleAddToCart}
              className="w-full py-4 bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white font-bold rounded-xl transition-colors text-base"
            >
              {inCart > 0 ? `Add More to Cart (+${quantity})` : "Add to Cart 🛒"}
            </button>
          </div>
        )}

        {/* Reviews */}
        {reviews.length > 0 && (
          <div className="bg-white rounded-2xl shadow-sm p-5 mt-3">
            <h3 className="font-bold text-gray-900 mb-3 flex items-center gap-2">
              <span className="text-amber-400">★</span> Reviews for {item.cookName}
            </h3>
            <div className="space-y-3">
              {reviews.slice(0, 4).map((review) => (
                <div key={review.id} className="border-b border-gray-100 last:border-0 pb-3 last:pb-0">
                  <div className="flex items-center justify-between mb-1">
                    <p className="text-sm font-medium text-gray-800">{review.buyerName}</p>
                    <div className="flex gap-0.5">
                      {[1, 2, 3, 4, 5].map((s) => (
                        <span key={s} className={`text-sm ${s <= review.rating ? "text-amber-400" : "text-gray-200"}`}>★</span>
                      ))}
                    </div>
                  </div>
                  <p className="text-xs text-gray-500 mb-0.5">{review.itemName}</p>
                  {review.comment && <p className="text-sm text-gray-600 italic">"{review.comment}"</p>}
                </div>
              ))}
            </div>
          </div>
        )}
      </main>

      {/* Sticky cart bar */}
      {totalItems > 0 && (
        <div className="fixed bottom-0 left-0 right-0 z-30 px-4 pb-4 pointer-events-none">
          <button
            onClick={() => navigate("/cart")}
            className="pointer-events-auto w-full max-w-lg mx-auto flex items-center justify-between bg-orange-600 text-white px-5 py-3.5 rounded-2xl shadow-2xl"
          >
            <span className="bg-orange-500 text-white text-xs font-bold px-2 py-0.5 rounded-full">
              {totalItems}
            </span>
            <span className="font-bold text-base">View Cart</span>
            <span className="font-semibold text-orange-200 text-sm">Go →</span>
          </button>
        </div>
      )}
    </div>
  );
}


