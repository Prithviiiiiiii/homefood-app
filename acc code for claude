import { useState, useEffect } from "react";
import { useLocation } from "wouter";
import { useAuth } from "@/contexts/AuthContext";
import { getCookOrders, markOrderDelivered, Order } from "@/lib/firestore";
import { MOCK_ORDERS } from "@/lib/mockData";
import { useToast } from "@/hooks/use-toast";

export default function OrderSummaryPage() {
  const { userProfile, isDemoMode } = useAuth();
  const [, navigate] = useLocation();
  const { toast } = useToast();
  const [orders, setOrders] = useState<Order[]>([]);
  const [loading, setLoading] = useState(true);
  const [marking, setMarking] = useState<string | null>(null);

  const fetchOrders = async () => {
    setLoading(true);
    try {
      if (isDemoMode) {
        const sorted = [...MOCK_ORDERS].sort((a, b) => {
          if (a.status === "placed" && b.status === "delivered") return -1;
          if (a.status === "delivered" && b.status === "placed") return 1;
          return 0;
        });
        setOrders(sorted);
        return;
      }
      if (!userProfile) return;
      const data = await getCookOrders(userProfile.uid);
      data.sort((a, b) => {
        if (a.status === "placed" && b.status === "delivered") return -1;
        if (a.status === "delivered" && b.status === "placed") return 1;
        return 0;
      });
      setOrders(data);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchOrders();
  }, [userProfile, isDemoMode]);

  const handleMarkDelivered = async (orderId: string) => {
    setMarking(orderId);
    try {
      if (isDemoMode) {
        setOrders((prev) =>
          prev.map((o) => (o.id === orderId ? { ...o, status: "delivered" } : o))
        );
        toast({ title: "Marked as delivered (Demo)" });
        return;
      }
      await markOrderDelivered(orderId);
      setOrders((prev) =>
        prev.map((o) => (o.id === orderId ? { ...o, status: "delivered" } : o))
      );
      toast({ title: "Marked as delivered" });
    } catch (err: unknown) {
      const error = err as Error;
      toast({ title: "Failed to update", description: error.message, variant: "destructive" });
    } finally {
      setMarking(null);
    }
  };

  const placed = orders.filter((o) => o.status === "placed");
  const delivered = orders.filter((o) => o.status === "delivered");
  const totalRevenue = placed.reduce((sum, o) => sum + o.totalPrice, 0);

  return (
    <div className="min-h-screen bg-orange-50 pb-16">
      <header className="bg-orange-500 text-white px-4 pt-10 pb-4 flex items-center gap-3 shadow-md">
        <button onClick={() => navigate("/cook")} className="text-white text-2xl leading-none">
          ←
        </button>
        <div>
          <h1 className="font-semibold text-lg">Today's Orders</h1>
          <p className="text-orange-100 text-xs">
            {orders.length} order{orders.length !== 1 ? "s" : ""}
            {placed.length > 0 && ` · ₹${totalRevenue} pending`}
          </p>
        </div>
      </header>

      <main className="px-4 py-5 max-w-lg mx-auto">
        {loading ? (
          <div className="text-center py-12 text-gray-400">Loading orders...</div>
        ) : orders.length === 0 ? (
          <div className="bg-white rounded-2xl p-8 text-center text-gray-400 border border-orange-100">
            <div className="text-4xl mb-2">📭</div>
            <p className="font-medium text-gray-500">No orders yet</p>
            <p className="text-sm mt-1">Orders will appear here once buyers place them</p>
          </div>
        ) : (
          <div className="space-y-4">
            {placed.length > 0 && (
              <div>
                <h2 className="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-2">
                  Pending ({placed.length})
                </h2>
                <div className="space-y-3">
                  {placed.map((order) => (
                    <OrderCard
                      key={order.id}
                      order={order}
                      onMarkDelivered={handleMarkDelivered}
                      marking={marking === order.id}
                    />
                  ))}
                </div>
              </div>
            )}

            {delivered.length > 0 && (
              <div>
                <h2 className="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-2">
                  Delivered ({delivered.length})
                </h2>
                <div className="space-y-3">
                  {delivered.map((order) => (
                    <OrderCard
                      key={order.id}
                      order={order}
                      onMarkDelivered={handleMarkDelivered}
                      marking={marking === order.id}
                    />
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </main>
    </div>
  );
}

function OrderCard({
  order,
  onMarkDelivered,
  marking,
}: {
  order: Order;
  onMarkDelivered: (id: string) => void;
  marking: boolean;
}) {
  return (
    <div
      className={`bg-white rounded-2xl p-4 border shadow-sm ${
        order.status === "delivered"
          ? "border-green-100 opacity-75"
          : "border-orange-100"
      }`}
    >
      <div className="flex items-start justify-between gap-2">
        <div className="flex-1 min-w-0">
          <h3 className="font-semibold text-gray-900 truncate">{order.itemName}</h3>
          <p className="text-sm text-orange-500 mt-0.5">Flat {order.flatNumber}</p>
        </div>
        <span className="text-orange-600 font-bold whitespace-nowrap">₹{order.totalPrice}</span>
      </div>

      <div className="mt-2 flex items-center gap-4 text-sm text-gray-500">
        <span>Qty: {order.quantity}</span>
        {order.specialNote && (
          <span className="text-xs bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full truncate max-w-[150px]">
            "{order.specialNote}"
          </span>
        )}
      </div>

      <div className="mt-3 flex items-center justify-between">
        {order.status === "delivered" ? (
          <span className="text-xs text-green-600 font-semibold bg-green-50 px-3 py-1.5 rounded-full">
            Delivered
          </span>
        ) : (
          <button
            onClick={() => onMarkDelivered(order.id)}
            disabled={marking}
            className="py-2 px-4 bg-orange-500 hover:bg-orange-600 active:bg-orange-700 text-white text-sm font-semibold rounded-xl transition-colors disabled:opacity-60"
          >
            {marking ? "Updating..." : "Mark Delivered"}
          </button>
        )}
      </div>
    </div>
  );
}


