  const today = getTodayDate();
  const q = query(
    collection(getDb(), "menuItems"),
    where("date", "==", today),
    where("isAvailable", "==", true)
  );
  const snap = await getDocs(q);
  return snap.docs.map((d) => ({ id: d.id, ...d.data() } as MenuItem));
}

